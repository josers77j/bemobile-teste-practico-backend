# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name

# Gateway 1
GATEWAY1_URL=http://localhost:3001
GATEWAY1_EMAIL=your_gateway1_email
GATEWAY1_TOKEN=your_gateway1_token

# Gateway 2
GATEWAY2_URL=http://localhost:3002
GATEWAY2_AUTH_TOKEN=your_gateway2_auth_token
GATEWAY2_AUTH_SECRET=your_gateway2_auth_secret

#--------------------------------------------------------------------
# CORS (configure allowed origins for API access)
#--------------------------------------------------------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
